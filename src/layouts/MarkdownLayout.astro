---
import BaseLayout from './BaseLayout.astro';
import TableOfContents from '../components/TableOfContents.astro';

interface Heading { depth: number; slug: string; text: string; }

interface Props {
  title: string;
  description?: string;
  game: string;
  breadcrumb: { label: string; href: string }[];
  headings?: Heading[];
  publishedAt?: string;
  updatedAt?: string;
}

const { title, description, game, breadcrumb, headings = [], publishedAt, updatedAt } = Astro.props;

// YYYY-MM-DD → 日本語表記に変換
function formatDate(iso: string): string {
  const [y, m, d] = iso.split('-');
  return `${y}年${Number(m)}月${Number(d)}日`;
}
const filtered = headings.filter(h => h.depth <= 3);
const pageTitle = `${game} ${title}`;
const canonicalURL = new URL(Astro.url.pathname, Astro.site).href;

// BreadcrumbList 構造化データ
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'TOP', item: Astro.site?.href },
    ...breadcrumb.map(({ label, href }, i) => ({
      '@type': 'ListItem',
      position: i + 2,
      name: label,
      item: new URL(href, Astro.site).href,
    })),
    { '@type': 'ListItem', position: breadcrumb.length + 2, name: title },
  ],
};

// Article 構造化データ
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: pageTitle,
  ...(description ? { description } : {}),
  url: canonicalURL,
  ...(publishedAt ? { datePublished: publishedAt } : {}),
  ...(updatedAt ? { dateModified: updatedAt } : {}),
  author: { '@type': 'Person', name: 'ゆうやみ' },
  publisher: {
    '@type': 'Organization',
    name: 'CRADLE 2 GRAVE',
    url: Astro.site?.href,
  },
};
---

<BaseLayout title={pageTitle} description={description}>
  <script slot="head" is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script slot="head" is:inline type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  {filtered.length > 1 && (
    <TableOfContents slot="sidebar" headings={filtered} />
  )}

  <nav class="breadcrumb">
    <a href="/">TOP</a>
    {breadcrumb.map(({ label, href }) => (
      <>
        <span class="sep">›</span>
        <a href={href}>{label}</a>
      </>
    ))}
    <span class="sep">›</span>
    <span>{title}</span>
  </nav>

  <div class="page-header">
    <div class="game-label">{game}</div>
    <h1 class="page-title">{title}</h1>
    {(publishedAt || updatedAt) && (
      <div class="page-dates">
        {publishedAt && <span>執筆：{formatDate(publishedAt)}</span>}
        {updatedAt && <span>更新：{formatDate(updatedAt)}</span>}
      </div>
    )}
  </div>

  <article class="prose">
    <slot />
  </article>
</BaseLayout>

<style>
.breadcrumb {
  font-size: 0.8rem;
  color: var(--text-muted);
  margin-bottom: 1.5rem;
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 0.25rem;
}
.breadcrumb a { color: var(--text-muted); }
.breadcrumb a:hover { color: var(--text); }
.sep { opacity: 0.5; }

.page-header {
  margin-bottom: 2rem;
  padding-bottom: 0.75rem;
  border-bottom: 1px solid var(--border);
}

.game-label {
  font-size: 1.4rem;
  font-weight: 700;
  color: var(--accent-light);
  line-height: 1.3;
  margin-bottom: 0.3rem;
}

.page-title {
  font-size: 0.95rem;
  font-weight: 400;
  color: var(--text-muted);
  line-height: 1.4;
}

.page-dates {
  margin-top: 0.5rem;
  display: flex;
  gap: 1.25rem;
  font-size: 0.8rem;
  color: var(--text-muted);
}

:global(.prose hr) {
  border: none;
  border-top: 2px solid var(--border);
  margin: 1.5rem 0;
}
</style>
