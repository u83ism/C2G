---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import {
  staticCards,
  collectionUrlPrefixes,
  collectionGameMeta,
} from '../data/menu';
import type { GameCard, MenuLink } from '../data/menu';
import { manualUpdates } from '../data/updates';
import { buildUpdates } from '../lib/buildUpdates';

// ── Fetch collections ────────────────────────────────────────────────────────
const [civ6Entries, civRevEntries, slayEntries, amongUsEntries, ssxEntries, columnEntries, silentStormEntries] =
  await Promise.all([
    getCollection('civilization6'),
    getCollection('civilization-revolution'),
    getCollection('slay-the-spire'),
    getCollection('among-us'),
    getCollection('ssx'),
    getCollection('column'),
    getCollection('silent-storm'),
  ]);

// ── 単一ゲームコレクションをGameCardに変換 ──────────────────────────────────
function toCard(
  meta: { readonly title: string; readonly releaseYear: number },
  entries: { data: { title: string; wip?: boolean }; id: string }[],
  urlPrefix: string,
): GameCard {
  return {
    title: meta.title,
    releaseYear: meta.releaseYear,
    links: entries.map(e => ({ label: e.data.title, href: `${urlPrefix}/${e.id}`, wip: e.data.wip })),
  };
}

// ── 更新履歴用メタデータを構築 ──────────────────────────────────────────────
type MetaEntry = { data: { title: string; publishedAt?: string; updatedAt?: string } };
function toMetas(entries: MetaEntry[], gameName: string) {
  return entries.map(e => ({ title: e.data.title, game: gameName, publishedAt: e.data.publishedAt, updatedAt: e.data.updatedAt }));
}

// ── Build updates ────────────────────────────────────────────────────────────
const allContentMetas = [
  ...toMetas(silentStormEntries, collectionGameMeta['silent-storm'].title),
  ...toMetas(slayEntries,        collectionGameMeta['slay-the-spire'].title),
  ...toMetas(civ6Entries,        collectionGameMeta['civilization6'].title),
  ...toMetas(civRevEntries,      collectionGameMeta['civilization-revolution'].title),
  ...toMetas(amongUsEntries,     collectionGameMeta['among-us'].title),
  ...toMetas(ssxEntries,         collectionGameMeta['ssx'].title),
  ...columnEntries.map(e => ({ title: e.data.title, game: e.data.game, publishedAt: e.data.publishedAt, updatedAt: e.data.updatedAt })),
];
const recentUpdates = buildUpdates(manualUpdates, allContentMetas);

// YYYY-MM-DD → YYYY/MM/DD 表示用
const formatUpdateDate = (iso: string): string => iso.replaceAll('-', '/');

// 全カードをリリース年（新しい順）でソート
const allCards: GameCard[] = [
  ...staticCards,
  toCard(collectionGameMeta['silent-storm'],            silentStormEntries, collectionUrlPrefixes['silent-storm']),
  toCard(collectionGameMeta['slay-the-spire'],          slayEntries,        collectionUrlPrefixes['slay-the-spire']),
  toCard(collectionGameMeta['civilization6'],         civ6Entries,        collectionUrlPrefixes['civilization6']),
  toCard(collectionGameMeta['civilization-revolution'], civRevEntries,      collectionUrlPrefixes['civilization-revolution']),
  toCard(collectionGameMeta['among-us'],                amongUsEntries,     collectionUrlPrefixes['among-us']),
  toCard(collectionGameMeta['ssx'],                     ssxEntries,         collectionUrlPrefixes['ssx']),
].sort((a, b) => b.releaseYear - a.releaseYear);

---

<BaseLayout>
  <!-- 更新履歴 -->
  <div class="updates">
    <div class="section-label">更新履歴</div>
    <table>
      {recentUpdates.map(entry => (
        <tr>
          <td>{formatUpdateDate(entry.date)}</td>
          <td>
            <ul>
              {entry.items.map(item => <li>{item}</li>)}
            </ul>
          </td>
        </tr>
      ))}
    </table>
  </div>

  <!-- 攻略・メモ・考察 -->
  <div class="games-grid">
    {allCards.map(card => (
      <div class="game-card">
        <h2>
          {card.title}
          {card.subtitle && <small>{card.subtitle}</small>}
        </h2>
        <ul>
          {card.links.map((link: MenuLink) => (
            <li>
              {link.children ? (
                <>
                  <span class="group-label">{link.label}</span>
                  <ul class="group-children">
                    {link.children.map((child: MenuLink) => (
                      <li>
                        {child.href ? (
                          <a href={child.href} target={child.external ? '_blank' : undefined} rel={child.external ? 'noopener' : undefined}>
                            {child.label}{child.external && ' 🔗'}{child.wip && <span class="wip">（製作途中）</span>}
                          </a>
                        ) : (
                          <span class="wip">{child.label}（未）</span>
                        )}
                      </li>
                    ))}
                  </ul>
                </>
              ) : link.href ? (
                <a href={link.href} target={link.external ? '_blank' : undefined} rel={link.external ? 'noopener' : undefined}>
                  {link.label}{link.external && ' 🔗'}{link.wip && <span class="wip">（製作途中）</span>}
                </a>
              ) : (
                <span class="wip">{link.label}（未）</span>
              )}
            </li>
          ))}
        </ul>
      </div>
    ))}
  </div>
</BaseLayout>
