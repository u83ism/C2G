---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import {
  mainSection,
  staticMemoCards,
  collectionUrlPrefixes,
  memoCardOrder,
} from '../data/menu';
import type { GameCard, MenuLink } from '../data/menu';

// ── Fetch collections ────────────────────────────────────────────────────────
const [civilizationEntries, slayEntries, amongUsEntries, ssxEntries] =
  await Promise.all([
    getCollection('civilization'),
    getCollection('slayTheSpire'),
    getCollection('amongUs'),
    getCollection('ssx'),
  ]);

// ── Build collection-based GameCard[] (grouped by game field) ────────────────
type CollectionEntry = { id: string; data: { title: string; game: string; wip?: boolean } };

function toCards(entries: CollectionEntry[], urlPrefix: string): GameCard[] {
  const groups = new Map<string, MenuLink[]>();
  for (const e of entries) {
    const links = groups.get(e.data.game) ?? [];
    links.push({ label: e.data.title, href: `${urlPrefix}/${e.id}`, wip: e.data.wip });
    groups.set(e.data.game, links);
  }
  return Array.from(groups.entries()).map(([title, links]) => ({ title, links }));
}

const collectionMemoCards: GameCard[] = [
  ...toCards(slayEntries,        collectionUrlPrefixes.slayTheSpire),
  ...toCards(civilizationEntries, collectionUrlPrefixes.civilization),
  ...toCards(amongUsEntries,     collectionUrlPrefixes.amongUs),
  ...toCards(ssxEntries,         collectionUrlPrefixes.ssx),
];

// Merge collection cards + static cards, sort by memoCardOrder
const allMemoCards: GameCard[] = [
  ...collectionMemoCards,
  ...staticMemoCards,
].sort((a, b) => {
  const ai = memoCardOrder.indexOf(a.title);
  const bi = memoCardOrder.indexOf(b.title);
  return (ai === -1 ? Number.MAX_SAFE_INTEGER : ai) - (bi === -1 ? Number.MAX_SAFE_INTEGER : bi);
});

---

<BaseLayout>
  <!-- 更新履歴 -->
  <div class="updates">
    <div class="section-label">更新履歴</div>
    <table>
      <tr>
        <td>2025/10/12</td>
        <td>
          <ul>
            <li>Civ6についての雑文を書いたのでリンクを張りました</li>
            <li>リンク回りを整備</li>
          </ul>
        </td>
      </tr>
    </table>
  </div>

  <!-- 攻略・メモ・考察 -->
  <div class="games-grid">
    {[...mainSection.cards, ...allMemoCards].map(card => (
      <div class="game-card">
        <h2>
          {card.title}
          {card.subtitle && <small>{card.subtitle}</small>}
        </h2>
        <ul>
          {card.links.map(link => (
            <li>
              {link.children ? (
                <>
                  {link.label}
                  <ul>
                    {link.children.map(child => (
                      <li>
                        {child.href ? (
                          <a href={child.href} target={child.external ? '_blank' : undefined} rel={child.external ? 'noopener' : undefined}>
                            {child.label}{child.external && ' ↗'}{child.wip && <span class="wip">（製作途中）</span>}
                          </a>
                        ) : (
                          <span class="wip">{child.label}（未）</span>
                        )}
                      </li>
                    ))}
                  </ul>
                </>
              ) : link.href ? (
                <a href={link.href} target={link.external ? '_blank' : undefined} rel={link.external ? 'noopener' : undefined}>
                  {link.label}{link.external && ' ↗'}{link.wip && <span class="wip">（製作途中）</span>}
                </a>
              ) : (
                <span class="wip">{link.label}（未）</span>
              )}
            </li>
          ))}
        </ul>
      </div>
    ))}
  </div>
</BaseLayout>
