---
import BaseLayout from './BaseLayout.astro';
import TableOfContents from '../components/TableOfContents.astro';

interface Heading { depth: number; slug: string; text: string; }

interface Props {
  title: string;
  description?: string;
  game: string;
  breadcrumb: { label: string; href: string }[];
  headings?: Heading[];
}

const { title, description, game, breadcrumb, headings = [] } = Astro.props;
const filtered = headings.filter(h => h.depth <= 3);
---

<BaseLayout title={title} description={description}>
  {filtered.length > 1 && (
    <TableOfContents slot="sidebar" headings={headings} />
  )}

  <nav class="breadcrumb">
    <a href="/">TOP</a>
    {breadcrumb.map(({ label, href }) => (
      <>
        <span class="sep">›</span>
        <a href={href}>{label}</a>
      </>
    ))}
    <span class="sep">›</span>
    <span>{title}</span>
  </nav>

  <div class="page-header">
    <h1 class="page-title">{title}</h1>
    <div class="game-label">{game}</div>
  </div>

  <article class="prose">
    <slot />
  </article>
</BaseLayout>

<style>
.breadcrumb {
  font-size: 0.8rem;
  color: var(--text-muted);
  margin-bottom: 1.5rem;
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 0.25rem;
}
.breadcrumb a { color: var(--text-muted); }
.breadcrumb a:hover { color: var(--text); }
.sep { opacity: 0.5; }

.page-header {
  margin-bottom: 2rem;
  padding-bottom: 0.75rem;
  border-bottom: 1px solid var(--border);
}

.page-title {
  font-size: 1.35rem;
  font-weight: 700;
  line-height: 1.3;
  margin-bottom: 0.3rem;
}

.game-label {
  font-size: 1rem;
  font-weight: 600;
  color: var(--accent);
}

:global(.prose hr) {
  border: none;
  border-top: 2px solid var(--border);
  margin: 1.5rem 0;
}
</style>
