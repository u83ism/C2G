---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import {
  staticCards,
  collectionUrlPrefixes,
} from '../data/menu';
import type { GameCard, MenuLink } from '../data/menu';

// ── Fetch collections ────────────────────────────────────────────────────────
const [civilizationEntries, slayEntries, amongUsEntries, ssxEntries] =
  await Promise.all([
    getCollection('civilization'),
    getCollection('slay-the-spire'),
    getCollection('among-us'),
    getCollection('ssx'),
  ]);

// ── Build collection-based GameCard[] (grouped by game field) ────────────────
type CollectionEntry = { id: string; data: { title: string; game: string; releaseYear: number; wip?: boolean } };

function toCards(entries: CollectionEntry[], urlPrefix: string): GameCard[] {
  const groups = new Map<string, { links: MenuLink[]; releaseYear: number }>();
  for (const e of entries) {
    const group = groups.get(e.data.game) ?? { links: [], releaseYear: e.data.releaseYear };
    group.links.push({ label: e.data.title, href: `${urlPrefix}/${e.id}`, wip: e.data.wip });
    groups.set(e.data.game, group);
  }
  return Array.from(groups.entries()).map(([title, { links, releaseYear }]) => ({ title, links, releaseYear }));
}

// 全カードをリリース年（新しい順）でソート
const allCards: GameCard[] = [
  ...staticCards,
  ...toCards(slayEntries,        collectionUrlPrefixes['slay-the-spire']),
  ...toCards(civilizationEntries, collectionUrlPrefixes.civilization),
  ...toCards(amongUsEntries,     collectionUrlPrefixes['among-us']),
  ...toCards(ssxEntries,         collectionUrlPrefixes.ssx),
].sort((a, b) => b.releaseYear - a.releaseYear);

---

<BaseLayout>
  <!-- 更新履歴 -->
  <div class="updates">
    <div class="section-label">更新履歴</div>
    <table>
      <tr>
        <td>2025/10/12</td>
        <td>
          <ul>
            <li>Civ6についての雑文を書いたのでリンクを張りました</li>
            <li>リンク回りを整備</li>
          </ul>
        </td>
      </tr>
    </table>
  </div>

  <!-- 攻略・メモ・考察 -->
  <div class="games-grid">
    {allCards.map(card => (
      <div class="game-card">
        <h2>
          {card.title}
          {card.subtitle && <small>{card.subtitle}</small>}
        </h2>
        <ul>
          {card.links.map((link: MenuLink) => (
            <li>
              {link.children ? (
                <>
                  <span class="group-label">{link.label}</span>
                  <ul class="group-children">
                    {link.children.map((child: MenuLink) => (
                      <li>
                        {child.href ? (
                          <a href={child.href} target={child.external ? '_blank' : undefined} rel={child.external ? 'noopener' : undefined}>
                            {child.label}{child.external && ' ↗'}{child.wip && <span class="wip">（製作途中）</span>}
                          </a>
                        ) : (
                          <span class="wip">{child.label}（未）</span>
                        )}
                      </li>
                    ))}
                  </ul>
                </>
              ) : link.href ? (
                <a href={link.href} target={link.external ? '_blank' : undefined} rel={link.external ? 'noopener' : undefined}>
                  {link.label}{link.external && ' ↗'}{link.wip && <span class="wip">（製作途中）</span>}
                </a>
              ) : (
                <span class="wip">{link.label}（未）</span>
              )}
            </li>
          ))}
        </ul>
      </div>
    ))}
  </div>
</BaseLayout>
