import MarkdownLayout from '../../layouts/MarkdownLayout.astro';

const headings = [
  { depth: 2, slug: 'skills',  text: '早撃ちデータ及び考察' },
  { depth: 2, slug: 'force',   text: 'フォースアビリティデータ及び考察' },
  { depth: 2, slug: 'equip',   text: '最強装備案' },
  { depth: 2, slug: 'battle',  text: '戦術まとめ' },
];

type Skill = {
  readonly name: string;
  readonly mp: number;
  readonly effect: string;
  readonly comment: string;
};

const skills: readonly Skill[] = [
